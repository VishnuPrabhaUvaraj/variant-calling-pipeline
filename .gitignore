# Large data files - never commit these
data/raw/*.fastq.gz
data/trimmed/*.fastq.gz
data/reference/*.fa
data/reference/*.fa.gz
data/reference/*.vcf.gz

# BAM/alignment files
results/alignment/*.bam
results/alignment/*.bai
results/variants/*.bam
results/variants/*.vcf.gz

# Python
*.pyc
__pycache__/
.ipynb_checkpoints/

# Logs (optional - you can commit these if you want)
logs/*.log
